# Copy this file to .env and fill in values

# Server
PORT=3000

# JWT — change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h

# Database — SQLite file path (relative to backend/)
# To migrate to PostgreSQL/MySQL later, replace database.js only
DB_PATH=./pums.db

# Seed admin credentials (used on first run only)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_NAME=System Administrator
